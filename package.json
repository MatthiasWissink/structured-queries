{
  "name": "structured-queries",
  "version": "1.0.0",
  "description": "Type-safe, hierarchical query options factories for TanStack Query — define and organise your queries as a structured, composable tree.",
  "keywords": [
    "tanstack-query",
    "react-query",
    "query-options",
    "query-factory",
    "query-keys",
    "query-tree",
    "typescript",
    "type-safe",
    "react",
    "data-fetching",
    "caching",
    "structured-queries"
  ],
  "homepage": "https://github.com/MatthiasWissink/structured-queries#readme",
  "bugs": {
    "url": "https://github.com/MatthiasWissink/structured-queries/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatthiasWissink/structured-queries.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "author": "Matthias Wissink",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "@tanstack/query-core": ">=5.0.0"
  },
  "devDependencies": {
    "@tanstack/query-core": "^5.62.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
